# =====================================================
# .env.example — Plantilla de variables de entorno
# =====================================================
# Este archivo NO contiene valores reales.
# Copia este archivo como .env.local y llena los valores ahí.
# .env.local NUNCA se commitea (está en .gitignore).
#
# Comando para crear tu .env.local:
#   cp .env.example .env.local
# =====================================================

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# NEXT_PUBLIC_* expuestas al navegador (mismo valor que las anteriores)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Direct Postgres URL (pooler) — usada por pg-boss y migraciones CLI.
# Formato: postgresql://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres
SUPABASE_DB_PASSWORD=
SUPABASE_DB_URL_DIRECT=

# --- LLM Providers ---
# Proveedor activo: openai | anthropic | gemini | groq
# Cambia esta variable para usar un proveedor diferente.
# Solo necesitas configurar la API key del proveedor seleccionado.
LLM_PROVIDER=openai

OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=regis-system@dmaori.com

# --- WhatsApp (Wati) ---
WATI_API_KEY=
WATI_API_URL=
WATI_PHONE_NUMBER=

# --- n8n self-hosted ---
N8N_API_KEY=
N8N_URL=

# --- Project ---
SUPERVISOR_EMAIL=maori.david@dmaori.com
APP_ENV=development

// =========================================================
// ERD v0 — Regis SG-SST Platform (DBML format)
// Versión: v0  |  Fecha: 2026-04-28  |  Autor: Operador-Agent
// Tarea: T-F0-018  |  Issue: #13
// Render: pegar en https://dbdiagram.io/d para visualización interactiva
// =========================================================

Project regis_sgsst {
  database_type: 'PostgreSQL'
  Note: '''
    ERD v0 — Plataforma SG-SST Regis Colombia.
    Multi-tenant: regis_org_id (consultora) + company_id (empresa cliente).
    Soft delete: deleted_at en tablas operacionales.
    Auditoría inmutable particionada por mes en audit_log.
  '''
}

// =========================================================
// TENANCY & CATÁLOGOS
// =========================================================

Table regis_orgs {
  id uuid [pk]
  nombre text [not null]
  nit text [unique, not null]
  contact_email text
  plan_tier text [default: 'starter']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  Note: 'Top tenant: organizaciones consultoras que administran N empresas.'
}

Table companies {
  id uuid [pk]
  regis_org_id uuid [ref: > regis_orgs.id, not null]
  razon_social text [not null]
  nit text [unique, not null]
  ciiu_principal text [ref: > ciiu_codes.codigo]
  clase_riesgo_principal int
  n_trabajadores_estimado int
  departamento text
  ciudad text
  email_contacto text
  telefono text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  Indexes {
    regis_org_id
    (deleted_at) [name: 'idx_companies_active']
  }
  Note: 'Empresas cliente. Multi-tenant por regis_org_id.'
}

Table centros_de_trabajo {
  id uuid [pk]
  company_id uuid [ref: > companies.id, not null]
  nombre text [not null]
  direccion text
  departamento text
  ciudad text
  ciiu_centro text [ref: > ciiu_codes.codigo]
  clase_riesgo_centro int
  n_trabajadores int
  es_principal boolean [default: false]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  Note: 'Entidad de primera clase (ADR-02). Una empresa puede tener N centros con CIIU/riesgo distintos.'
}

Table ciiu_codes {
  codigo text [pk]
  descripcion text [not null]
  clase_riesgo int [not null, note: 'I=1 ... V=5']
  division text
  grupo text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  Note: 'Catálogo público DANE CIIU rev.4. Clase de riesgo Decreto 1607/2002.'
}

Table ciiu_hazard_mapping {
  id uuid [pk]
  ciiu_codigo text [ref: > ciiu_codes.codigo, not null]
  peligro_categoria text [not null]
  peligro_descripcion text [not null]
  fuente_referencia text
  prioridad int [default: 3]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  Note: 'Mapeo CIIU → peligros típicos GTC-45 (D-002). Catálogo nuevo a poblar con datos públicos.'
}

Table empresa_ciiu {
  id uuid [pk]
  company_id uuid [ref: > companies.id, not null]
  ciiu_codigo text [ref: > ciiu_codes.codigo, not null]
  es_principal boolean [default: false]
  valid_from timestamptz [not null, default: `now()`]
  valid_to timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    (company_id, ciiu_codigo) [unique]
  }
  Note: 'N:M companies <-> ciiu_codes. Una empresa puede tener múltiples CIIU (ADR-02).'
}

Table eps_catalog {
  id uuid [pk]
  codigo text [unique, not null]
  nombre text [not null]
  tipo_regimen text
  activo boolean [default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table afp_catalog {
  id uuid [pk]
  codigo text [unique, not null]
  nombre text [not null]
  activo boolean [default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table arl_catalog {
  id uuid [pk]
  codigo text [unique, not null]
  nombre text [not null]
  activo boolean [default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table document_types {
  id uuid [pk]
  codigo text [unique, not null]
  nombre text [not null]
  categoria text
  requiere_vigencia boolean [default: false]
  retencion_meses int
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table standards_0312 {
  id uuid [pk]
  codigo text [unique, not null, note: 'p.ej. 1.1.1, 2.3.5']
  titulo text [not null]
  descripcion text
  peso numeric [not null, note: 'peso porcentual del estándar']
  ciclo_phva text [note: 'Planear|Hacer|Verificar|Actuar']
  capitulo text
  aplica_desde_trabajadores int
  aplica_hasta_trabajadores int
  clase_riesgo_aplica text [note: 'p.ej. I-V o I,II,III']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  Note: '60 estándares de Resolución 0312/2019.'
}

// =========================================================
// PERSONAS Y ROLES
// =========================================================

Table users {
  id uuid [pk]
  email text [unique, not null]
  nombre_completo text
  auth_provider text [default: 'supabase']
  auth_provider_id text
  last_login_at timestamptz
  activo boolean [default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
}

Table roles {
  id uuid [pk]
  codigo text [unique, not null, note: 'regis_admin|regis_consultant|client_admin|worker']
  nombre text [not null]
  descripcion text
  permisos jsonb
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table user_company_role {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  company_id uuid [ref: > companies.id]
  role_id uuid [ref: > roles.id, not null]
  regis_org_id uuid [ref: > regis_orgs.id]
  valid_from timestamptz [not null, default: `now()`]
  valid_to timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  Indexes {
    (user_id, company_id, role_id) [unique, name: 'uniq_active_role']
  }
  Note: 'N:M users <-> companies con rol. company_id null = scope consultora.'
}

Table workers {
  id uuid [pk]
  tipo_documento text [not null, note: 'CC|CE|TI|PEP|PPT']
  numero_documento text [unique, not null]
  nombres text [not null]
  apellidos text [not null]
  fecha_nacimiento date
  genero text
  telefono text
  email text
  eps_id uuid [ref: > eps_catalog.id]
  afp_id uuid [ref: > afp_catalog.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  Note: 'Persona física. PK natural via numero_documento (UK).'
}

Table worker_company {
  id uuid [pk]
  worker_id uuid [ref: > workers.id, not null]
  company_id uuid [ref: > companies.id, not null]
  centro_id uuid [ref: > centros_de_trabajo.id]
  cargo text
  tipo_contrato text
  arl_id uuid [ref: > arl_catalog.id]
  fecha_ingreso date
  fecha_retiro date
  activo boolean [default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  Indexes {
    (worker_id, company_id, fecha_ingreso) [unique]
    company_id
  }
  Note: 'N:M workers <-> companies con historia laboral.'
}

// =========================================================
// CUMPLIMIENTO
// =========================================================

Table standard_evaluations {
  id uuid [pk]
  company_id uuid [ref: > companies.id, not null]
  centro_id uuid [ref: > centros_de_trabajo.id]
  standard_id uuid [ref: > standards_0312.id, not null]
  status text [not null, note: 'cumple|no_cumple|no_aplica|pendiente']
  peso_obtenido numeric
  justificacion text
  evidencia_documento_id uuid [ref: > documents.id]
  evaluado_por_user_id uuid [ref: > users.id]
  evaluado_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    (company_id, centro_id, standard_id) [unique, name: 'uniq_eval_per_scope']
  }
}

Table evaluation_snapshots {
  id uuid [pk]
  company_id uuid [ref: > companies.id, not null]
  centro_id uuid [ref: > centros_de_trabajo.id]
  snapshot_month date [not null, note: 'primer día del mes']
  porcentaje_global numeric
  breakdown_phva jsonb
  breakdown_capitulos jsonb
  status_general text [note: 'critico|moderado|aceptable']
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (company_id, centro_id, snapshot_month) [unique]
  }
  Note: 'Snapshots inmutables mensuales. No tienen updated_at ni deleted_at.'
}

Table documents {
  id uuid [pk]
  company_id uuid [ref: > companies.id, not null]
  centro_id uuid [ref: > centros_de_trabajo.id]
  document_type_id uuid [ref: > document_types.id, not null]
  titulo text [not null]
  version text
  file_url text [not null]
  file_hash text
  file_size_bytes bigint
  valid_from date
  valid_until date
  uploaded_by_user_id uuid [ref: > users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
}

// =========================================================
// COMITÉS
// =========================================================

Table committees {
  id uuid [pk]
  company_id uuid [ref: > companies.id, not null]
  centro_id uuid [ref: > centros_de_trabajo.id]
  tipo text [not null, note: 'COPASST|CONVIVENCIA|BRIGADA']
  nombre text
  constituido_el date
  vigencia_hasta date
  activo boolean [default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
}

Table committee_members {
  id uuid [pk]
  committee_id uuid [ref: > committees.id, not null]
  worker_id uuid [ref: > workers.id, not null]
  rol text [note: 'principal|suplente|presidente|secretario']
  representacion text [note: 'empleador|trabajadores']
  desde date
  hasta date
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
}

Table meeting_actas {
  id uuid [pk]
  committee_id uuid [ref: > committees.id, not null]
  fecha date [not null]
  lugar text
  agenda text
  contenido_md text
  file_url text
  generada_por_user_id uuid [ref: > users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
}

Table compromisos {
  id uuid [pk]
  acta_id uuid [ref: > meeting_actas.id, not null]
  descripcion text [not null]
  responsable_worker_id uuid [ref: > workers.id]
  fecha_compromiso date
  fecha_cumplimiento date
  status text [default: 'pendiente', note: 'pendiente|en_progreso|cumplido|vencido']
  evidencia_url text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
}

// =========================================================
// ESPECIALIZADAS
// =========================================================

Table medical_exams {
  id uuid [pk]
  worker_id uuid [ref: > workers.id, not null]
  company_id uuid [ref: > companies.id, not null]
  tipo_examen text [note: 'ingreso|periodico|egreso|post_incapacidad']
  fecha_examen date
  concepto_aptitud text [note: 'apto|apto_con_recomendaciones|no_apto']
  recomendaciones jsonb
  file_url_secure text [note: 'URL en bucket privado con retention 20 años']
  bucket_name text [default: 'medical_exams_secure']
  retention_years int [default: 20]
  extracted_by_ai_run_id uuid [ref: > ai_usage.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  Note: 'Datos sensibles (Ley 1581 categoría especial). Bucket separado, RLS estricta, retención 20 años Ley 1562/2012.'
}

Table risk_matrices {
  id uuid [pk]
  company_id uuid [ref: > companies.id, not null]
  centro_id uuid [ref: > centros_de_trabajo.id]
  version text [not null]
  metodologia text [default: 'GTC-45']
  peligros jsonb
  evaluacion jsonb
  status text [default: 'borrador', note: 'borrador|en_revision|aprobada|archivada']
  aprobada_por_user_id uuid [ref: > users.id]
  aprobada_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
}

Table emergency_plans {
  id uuid [pk]
  company_id uuid [ref: > companies.id, not null]
  centro_id uuid [ref: > centros_de_trabajo.id]
  version text [not null]
  contenido_md text
  brigadas jsonb
  rutas_evacuacion jsonb
  vigencia_desde date
  vigencia_hasta date
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
}

Table furat_reports {
  id uuid [pk]
  company_id uuid [ref: > companies.id, not null]
  centro_id uuid [ref: > centros_de_trabajo.id]
  worker_id uuid [ref: > workers.id, not null]
  numero_reporte text [unique]
  fecha_accidente date
  tipo_accidente text
  descripcion text
  parte_cuerpo_afectada text
  severidad text [note: 'leve|grave|mortal']
  reportado_arl boolean [default: false]
  fecha_reporte_arl date
  file_url text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
}

// =========================================================
// SISTEMA
// =========================================================

Table audit_log {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`, note: 'partition key (mes)']
  actor_user_id uuid [ref: > users.id]
  actor_type text [note: 'user|operador_agent|qa_agent|pm_agent|auditor_agent|system']
  action text [not null, note: 'create|update|delete|approve|login|...']
  entity_type text [not null]
  entity_id uuid
  company_id uuid [ref: > companies.id]
  regis_org_id uuid [ref: > regis_orgs.id]
  old_values jsonb
  new_values jsonb
  ip_address text
  user_agent text

  Indexes {
    (created_at) [name: 'idx_audit_partition']
    (entity_type, entity_id)
    company_id
  }
  Note: 'Particionado por mes (RANGE on created_at). Append-only — sin updated_at ni deleted_at.'
}

Table consents {
  id uuid [pk]
  worker_id uuid [ref: > workers.id]
  company_id uuid [ref: > companies.id]
  consent_type text [not null, note: 'habeas_data|datos_sensibles|comunicaciones']
  version_politica text [not null]
  texto_aceptado text
  aceptado_at timestamptz [not null]
  canal text [note: 'web|whatsapp|email|presencial']
  ip_address text
  revocado_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  Note: 'Habeas Data Ley 1581/2012. Inmutable salvo revocación.'
}

Table notifications {
  id uuid [pk]
  recipient_user_id uuid [ref: > users.id]
  recipient_worker_id uuid [ref: > workers.id]
  channel text [not null, note: 'email|whatsapp|in_app|sms']
  template_codigo text
  payload jsonb
  status text [default: 'pendiente', note: 'pendiente|enviado|fallido|reintentando']
  retry_count int [default: 0]
  error_message text
  scheduled_for timestamptz
  sent_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table ai_usage {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  agent_id text [note: 'operador_agent|qa_agent|pm_agent|auditor_agent']
  task_id text
  complexity_level text [note: 'trivial|simple|medium|complex|critical']
  provider text [note: 'anthropic|groq|gemini']
  model text
  prompt_tokens int
  completion_tokens int
  cost_usd numeric
  latency_ms int
  success boolean
  error_signature text
  request_hash text [note: 'hash(prompt+input) — usado por loop detector trigger 5']

  Indexes {
    (agent_id, created_at)
    request_hash
  }
}

Table ai_outputs_pending_review {
  id uuid [pk]
  ai_usage_id uuid [ref: > ai_usage.id]
  entity_type text [not null]
  entity_id uuid
  output_payload jsonb [not null]
  confidence numeric
  reason_for_review text
  status text [default: 'pendiente', note: 'pendiente|aprobado|rechazado']
  reviewed_by_user_id uuid [ref: > users.id]
  reviewed_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table pg_boss_jobs {
  id uuid [pk]
  name text [not null]
  data jsonb
  state text [not null, note: 'created|active|completed|failed|cancelled']
  retry_count int [default: 0]
  created_on timestamptz [not null, default: `now()`]
  started_on timestamptz
  completed_on timestamptz
  expire_in timestamptz
  Note: 'Tabla creada y administrada por la librería pg-boss.'
}

Table loop_detections {
  id uuid [pk]
  trigger_code text [not null, note: 'T1_REJECTIONS|T2_OVERDUE|T3_REPEAT_ERR|T4_LOW_APPROVAL|T5_DUP_PROMPT|T6_PM_CONTRADICT']
  severity text [default: 'medium']
  agent_id text
  task_id text
  evidence jsonb
  action_taken text [note: 'paused_task|paused_agent|notify_only']
  resolved boolean [default: false]
  resolved_at timestamptz
  created_at timestamptz [not null, default: `now()`]
}

Table auditor_findings {
  id uuid [pk]
  audit_run_id text [not null]
  severity text [default: 'medium']
  rule_violated text [not null]
  task_id text
  evidence jsonb
  recommended_action text
  status text [default: 'open', note: 'open|reviewed|dismissed|resolved']
  reviewed_by_user_id uuid [ref: > users.id]
  reviewed_at timestamptz
  created_at timestamptz [not null, default: `now()`]
}

// =========================================================
// REFERENCIAS ADICIONALES (atajos visuales en dbdiagram)
// =========================================================

Ref: standard_evaluations.evidencia_documento_id > documents.id
